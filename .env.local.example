# ─── Firebase Configuration ────────────────────────────────────────────────
# คัดลอกจาก Firebase Console → Project Settings → General → Your apps → Config
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ─── FCM Push Notification ──────────────────────────────────────────────────
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
# → Generate key pair → คัดลอก Key pair
NEXT_PUBLIC_FIREBASE_VAPID_KEY=BPxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── LINE Integration (Sprint 6) ───────────────────────────────────────────
# LINE Developers Console → Create Provider → Create Channel (LINE Login)
# https://developers.line.biz/console/
NEXT_PUBLIC_LINE_CHANNEL_ID=1234567890

# ─── App URL (สำหรับ LINE callback) ────────────────────────────────────────
# Development: http://localhost:3000
# Production:  https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── LINE Secrets (Cloud Functions ใช้ — ไม่ต้องใส่ตรงนี้) ─────────────────
# ตั้งค่าด้วยคำสั่ง:
#   firebase functions:secrets:set LINE_CHANNEL_SECRET
#   firebase functions:secrets:set LINE_CHANNEL_ACCESS_TOKEN
#   firebase functions:config:set line.channel_id="1234567890"
#   firebase functions:config:set app.url="https://yourdomain.com"

# ─── Firebase Admin SDK (สำหรับ /api/notify) ─────────────────────────────
# ดาวน์โหลดจาก Firebase Console → Project Settings → Service accounts
# → Generate new private key → เอาค่าจาก JSON file มาใส่
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@garageplus-66.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"

# ─── LINE Messaging API ──────────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxx
