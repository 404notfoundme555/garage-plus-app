rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read:  if request.auth.uid == userId || isStaff();
      allow write: if request.auth.uid == userId;
    }

    match /cars/{carId} {
      allow read:        if request.auth.uid == resource.data.userId || isStaff();
      allow create:      if request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth.uid == resource.data.userId;
    }

    match /bookings/{bookingId} {
      allow create:       if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth.uid == resource.data.userId || isStaff();
      allow delete:       if false;
    }

    match /repairs/{repairId} {
      allow read:  if request.auth.uid == resource.data.userId || isStaff();
      allow write: if isStaff();
      // allow create from staff with empty userId (walk-in customer)
      allow create: if isStaff();
    }

    match /slots/{date} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    match /notifications/{notifId} {
      allow read, update: if request.auth.uid == resource.data.userId || isStaff();
      allow create:       if isStaff() || request.auth != null;
      allow delete:       if false;
    }

    match /staff/{staffId} {
      allow read:   if request.auth.uid == staffId || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /articles/{articleId} {
      allow read:           if request.auth != null
                               && (resource.data.published == true || isStaff());
      allow create, update: if isStaff();
      allow delete:         if isAdmin();
    }

    match /config/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    match /promotions/{promoId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    function isStaff() {
      let s = get(/databases/$(database)/documents/staff/$(request.auth.uid));
      return s != null && s.data.role in ['admin', 'mechanic'];
    }
    function isAdmin() {
      let s = get(/databases/$(database)/documents/staff/$(request.auth.uid));
      return s != null && s.data.role == 'admin';
    }
  }
}
